# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://sherlock:sherlock_dev@localhost:5432/sherlock

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI / LLM ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ─── Service Ports ───────────────────────────────────────────
GATEWAY_PORT=3001
NOTIFICATION_PORT=3002
AI_ENGINE_PORT=8000
WEB_PORT=3000

# ─── Frontend (public) ──────────────────────────────────────
NEXT_PUBLIC_NOTIFICATION_URL=http://localhost:3002
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001

# ─── Feature Flags ──────────────────────────────────────────
ENABLE_METADATA_ENGINE=true
ENABLE_CONVERSATION_ENGINE=true
ENABLE_AUDIO_ENGINE=true
ENABLE_VIDEO_ENGINE=true
ENABLE_BEHAVIORAL_ENGINE=true
ENABLE_TEMPORAL_ENGINE=true

# ─── Confidence Thresholds ──────────────────────────────────
THRESHOLD_TENTATIVE=0.6
THRESHOLD_IDENTIFIED=0.8
THRESHOLD_CONFIRMED=0.95
DECAY_RATE=0.01

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Storage (Cloudflare R2) ────────────────────────────────
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=sherlock-sessions
